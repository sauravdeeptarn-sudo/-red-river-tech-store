<h1 class="mb-4">🛒 Your Shopping Cart</h1>

<% if @cart_items.empty? %>
  <div class="alert alert-info">
    Your cart is empty. <%= link_to "Continue Shopping", root_path, class: "alert-link" %>
  </div>
<% else %>
  <div class="table-responsive">
    <table class="table table-hover align-middle">
      <thead class="table-dark">
        <tr>
          <th>Product</th>
          <th>Price</th>
          <th>Quantity</th>
          <th>Subtotal</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @cart_items.each do |item| %>
          <tr>
            <td>
              <%= link_to item[:product].name, product_path(item[:product]) %>
            </td>
            <td>$<%= number_with_precision(item[:product].price, precision: 2) %></td>
            <td>
              <%= form_with url: update_cart_path(item[:product].id), method: :patch do |f| %>
                <div class="input-group" style="width: 120px;">
                  <%= f.number_field :quantity, value: item[:quantity], min: 1, class: "form-control form-control-sm" %>
                  <%= f.submit "Update", class: "btn btn-sm btn-outline-secondary" %>
                </div>
              <% end %>
            </td>
            <td>$<%= number_with_precision(item[:subtotal], precision: 2) %></td>
            <td>
              <%= link_to "Remove", remove_from_cart_path(item[:product].id), data: { turbo_method: :delete }, class: "btn btn-sm btn-danger" %>
            </td>
          </tr>
        <% end %>
      </tbody>
      <tfoot>
        <tr class="table-success">
          <td colspan="3"><strong>Total</strong></td>
          <td><strong>$<%= number_with_precision(@total, precision: 2) %></strong></td>
          <td></td>
        </tr>
      </tfoot>
    </table>
  </div>

  <div class="d-flex justify-content-between mt-3">
    <%= link_to "Continue Shopping", root_path, class: "btn btn-outline-primary" %>
 <%= link_to "Proceed to Checkout", new_order_path, class: "btn btn-success" %>
  </div>
<% end %>