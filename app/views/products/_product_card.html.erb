<div class="col">
  <div class="card h-100 shadow-sm">
    <div class="card-body">
      <span class="badge bg-primary mb-2"><%= product.category.name %></span>
      <h5 class="card-title"><%= product.name %></h5>
      <p class="card-text text-muted"><%= truncate(product.description, length: 100) %></p>
    </div>
    <div class="card-footer d-flex justify-content-between align-items-center">
      <span class="fs-5 fw-bold text-success">$<%= number_with_precision(product.price, precision: 2) %></span>
      <%= link_to "View Details", product_path(product), class: "btn btn-primary btn-sm" %>
    </div>
  </div>
</div>