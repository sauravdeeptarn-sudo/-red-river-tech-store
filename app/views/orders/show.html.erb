<h1 class="mb-4">✅ Order Confirmed!</h1>

<div class="card shadow-sm">
  <div class="card-header bg-success text-white">
    <h5 class="mb-0">Order #<%= @order.id %></h5>
  </div>
  <div class="card-body">
    <p><strong>Status:</strong> <span class="badge bg-warning"><%= @order.status %></span></p>
    <p><strong>Date:</strong> <%= @order.created_at.strftime("%B %d, %Y") %></p>
    <% if @province %>
      <p><strong>Province:</strong> <%= @province.name %></p>
    <% end %>

    <h5 class="mt-4">Items Ordered</h5>
    <table class="table">
      <thead>
        <tr>
          <th>Product</th>
          <th>Quantity</th>
          <th>Price at Purchase</th>
          <th>Subtotal</th>
        </tr>
      </thead>
      <tbody>
        <% @order_items.each do |item| %>
          <tr>
            <td><%= item.product.name %></td>
            <td><%= item.quantity %></td>
            <td>$<%= number_with_precision(item.price_at_purchase, precision: 2) %></td>
            <td>$<%= number_with_precision(item.price_at_purchase * item.quantity, precision: 2) %></td>
          </tr>
        <% end %>
      </tbody>
    </table>

    <div class="row justify-content-end">
      <div class="col-md-4">
        <table class="table table-sm">
          <tr>
            <td>Subtotal:</td>
            <td><strong>$<%= number_with_precision(@order.subtotal.to_f, precision: 2) %></strong></td>
          </tr>
          <% if @order.gst_amount.to_f > 0 %>
            <tr>
              <td>GST:</td>
              <td>$<%= number_with_precision(@order.gst_amount, precision: 2) %></td>
            </tr>
          <% end %>
          <% if @order.pst_amount.to_f > 0 %>
            <tr>
              <td>PST:</td>
              <td>$<%= number_with_precision(@order.pst_amount, precision: 2) %></td>
            </tr>
          <% end %>
          <% if @order.hst_amount.to_f > 0 %>
            <tr>
              <td>HST:</td>
              <td>$<%= number_with_precision(@order.hst_amount, precision: 2) %></td>
            </tr>
          <% end %>
          <tr class="table-success">
            <td><strong>Total:</strong></td>
            <td><strong>$<%= number_with_precision(@order.total_price, precision: 2) %></strong></td>
          </tr>
        </table>
      </div>
    </div>

    <% if @order.status == "pending" %>
  <%= link_to "💳 Pay Now", new_payment_path(order_id: @order.id), class: "btn btn-success btn-lg mt-3" %>
<% end %>
<%= link_to "Continue Shopping", root_path, class: "btn btn-primary mt-3 ms-2" %>
  </div>
</div>